PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/minlish

# JWT
JWT_SECRET=your_super_secret_key
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MAIL
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_mail
MAIL_PASS=your_password

# S3
BUCKET_NAME=
BUCKET_REGION=
AWS_ACCESS_KEY=
AWS_SECRET_ACCESS_KEY=
# Public/CDN base URL for reading uploaded objects (CloudFront domain or public bucket URL)
S3_PUBLIC_BASE_URL=

# Rate Limiting
LOGIN_LIMIT_WINDOW_MS=900000
LOGIN_LIMIT_MAX=5
REGISTER_LIMIT_WINDOW_MS=3600000
REGISTER_LIMIT_MAX=3

# Redis
REDIS_URL=redis://localhost:6379

# Otp
OTP_TTL=600 # 10m

# Gemini AI key
GEMINI_API_KEY=

# Azure API key
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# Timezone
GAMIFY_TZ=Asia/Ho_Chi_Minh
