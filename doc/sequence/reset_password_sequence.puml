@startuml Reset_Password_Sequence
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 8
skinparam responseMessageBelowArrow true
skinparam sequenceGroupBorderThickness 1.5

skinparam participant {
    BackgroundColor #EEF4FF
    BorderColor     #4A7CFF
    FontStyle       Bold
}
skinparam actor {
    BackgroundColor #FEFEFE
    BorderColor     #333333
}
skinparam sequence {
    LifeLineBorderColor  #888888
    GroupBorderColor     #888888
    GroupBodyBackgroundColor #FAFAFA
    DividerBackgroundColor   #E8E8E8
}
actor       "Khách vãng lai"    as User
participant "Giao diện"     as UI
participant "Hệ thống"      as Sys
database    "Cơ sở dữ liệu" as DB

User -> UI  : Truy cập trang "Quên mật khẩu"
activate UI
UI   --> User : Hiển thị form nhập email

User -> UI  : Nhập email + nhấn\n"Gửi yêu cầu khôi phục"

UI   -> Sys : Gửi yêu cầu khôi phục mật khẩu\n{ email }
activate Sys

Sys  -> DB  : Kiểm tra email trong CSDL
activate DB
DB   --> Sys : Kết quả (tồn tại / không tồn tại)
deactivate DB

alt Email chưa đăng ký hoặc sai định dạng
    Sys  --> UI   : Phản hồi lỗi
    UI   --> User : Thông báo lỗi:\n"Email không hợp lệ hoặc chưa được đăng ký"

else Email hợp lệ và tồn tại
    Sys  -> Sys  : Tạo mã OTP (6 chữ số)\nvà thời hạn hiệu lực
    Sys  -> DB   : Lưu mã OTP và thời hạn
    activate DB
    DB   --> Sys : Lưu thành công
    deactivate DB

    Sys --> User: Gửi email chứa mã OTP
    Sys  --> UI  : Phản hồi thành công
    UI  --> User : Thông báo thành công,\nChuyển sang trang Đặt lại mật khẩu
end

deactivate Sys
deactivate UI

User -> UI  : Truy cập trang "Đặt lại mật khẩu"
activate UI
UI   --> User : Hiển thị form:\n- 6 ô nhập OTP\n- Ô mật khẩu mới\n- Ô xác nhận mật khẩu mới\n- Đồng hồ đếm ngược 60 giây

User -> UI  : Nhập OTP, mật khẩu mới,\nxác nhận mật khẩu mới\n+ nhấn "Đặt lại mật khẩu"

UI   -> UI  : Kiểm tra đầu vào

alt OTP ít hơn 6 chữ số
    UI   --> User : Lỗi: "Vui lòng nhập đầy đủ\nmã xác thực gồm 6 chữ số"

else Mật khẩu mới bị trống
    UI   --> User : Lỗi: "Mật khẩu mới không được để trống"

else Mật khẩu xác nhận bị trống
    UI   --> User : Lỗi: "Mật khẩu xác nhận không được để trống"

else Xác nhận mật khẩu không khớp
    UI   --> User : Lỗi: "Mật khẩu xác nhận không trùng khớp"

else Mật khẩu mới ít hơn 6 ký tự
    UI   --> User : Lỗi: "Mật khẩu phải chứa tối thiểu 6 ký tự"

else Dữ liệu đầu vào hợp lệ
    UI   -> Sys  : Gửi yêu cầu đặt lại mật khẩu\n{ email, otpCode, newPassword }
    activate Sys

    Sys  -> DB   : Truy vấn mã OTP theo email
    activate DB
    DB   --> Sys : Mã OTP và thời hạn lưu trữ
    deactivate DB

    alt Mã OTP sai hoặc đã hết hạn
        Sys  --> UI   : Phản hồi lỗi xác thực OTP
        UI   --> User : Thông báo lỗi:\n"Mã OTP không hợp lệ hoặc đã hết hạn"

    else Mã OTP hợp lệ và còn hiệu lực
        Sys  -> Sys  : Mã hóa mật khẩu mới (bcrypt)

        Sys  -> DB   : Cập nhật mật khẩu mới đã mã hóa
        activate DB
        DB   --> Sys : Cập nhật thành công
        deactivate DB

        Sys  -> DB   : Xóa mã OTP đã dùng
        activate DB
        DB   --> Sys : Xóa thành công
        deactivate DB

        Sys  --> UI  : Phản hồi thành công
        UI   --> User : Thông báo "Cập nhật mật khẩu thành công!\nĐang chuyển hướng về trang Đăng nhập"
        UI   --> User : Chuyển hướng đến trang Đăng nhập
    end

    deactivate Sys
end
deactivate UI
@enduml
